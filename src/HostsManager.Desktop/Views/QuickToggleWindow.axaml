<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HostsManager.Desktop.ViewModels"
        x:Class="HostsManager.Desktop.Views.QuickToggleWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Hosts Manager"
        Width="340"
        Height="420"
        MinWidth="300"
        MinHeight="260"
        MaxWidth="420"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Button.iconAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="#C9D1D9" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.iconAction /template/ ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.iconAction:pointerover /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.iconAction:pressed /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.7" />
        </Style>
    </Window.Styles>

    <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
        <TextBlock Grid.Row="0" Text="Hosts Manager: Quick Source Toggle" FontSize="15" FontWeight="SemiBold" />

        <Border Grid.Row="1"
                IsVisible="{Binding HasPendingElevatedHostsUpdate}"
                Background="#3A2414"
                BorderBrush="#7A4A1F"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,6">
            <TextBlock Text="Pending hosts changes need administrator approval. Use Apply to elevate."
                       TextWrapping="Wrap"
                       Foreground="#FFD8A8"
                       FontSize="11" />
        </Border>

        <Border Grid.Row="2" BorderBrush="#2F3742" BorderThickness="1" CornerRadius="6" Background="#141A22" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="2,4">
                                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Opacity="0.65" FontSize="11" Text="{Binding SourceTypeDisplay}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="iconAction"
                                        VerticalAlignment="Center"
                                        Content="↻"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        IsVisible="{Binding IsRemoteSource}"
                                        ToolTip.Tip="Sync this remote source now"
                                        Click="SyncRemoteSourceClick" />
                                <ToggleSwitch Grid.Column="2"
                                              IsEnabled="{Binding CanToggleEnabled}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Checked="SourceEnabledChanged"
                                              Unchecked="SourceEnabledChanged" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Button Grid.Column="0" Content="Apply" Click="ApplyHostsClick" />
            <Button Grid.Column="1" Content="Exit App" Click="ExitAppClick" />
            <Button Grid.Column="2" Content="Open Full Editor" Click="OpenFullEditorClick" />
        </Grid>
    </Grid>
</Window>
