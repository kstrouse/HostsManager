<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HostsManager.Desktop.ViewModels"
    xmlns:views="using:HostsManager.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
    x:Class="HostsManager.Desktop.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/hosts-manager.ico"
        Title="Hosts Manager">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background" Value="#111315" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#191C20" />
            <Setter Property="BorderBrush" Value="#252A30" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <Grid Margin="16" RowDefinitions="*,Auto" RowSpacing="12">
        <Grid Grid.Row="0" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="340" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <views:SourceListView Grid.Column="0"
                                  DataContext="{Binding SourceList}" />

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#252A30"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <views:SourceEditorPaneView Grid.Column="2"
                                        DataContext="{Binding SourceEditor}" />
        </Grid>

        <views:StatusActionBarView Grid.Row="1"
                                   DataContext="{Binding StatusBar}" />
    </Grid>

</Window>
