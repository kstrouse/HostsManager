<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HostsManager.Desktop.ViewModels"
    xmlns:views="using:HostsManager.Desktop.Views"
    xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
    x:Class="HostsManager.Desktop.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/hosts-manager.ico"
        Title="Hosts Manager">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background" Value="#111315" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#191C20" />
            <Setter Property="BorderBrush" Value="#252A30" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <Grid Margin="16" RowDefinitions="*,Auto" RowSpacing="12">
        <Grid Grid.Row="0" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="340" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <views:SourceListView Grid.Column="0"
                                  DataContext="{Binding SourceList}" />

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#252A30"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <Border Classes="panel" Grid.Column="2" Padding="12">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                    <Border Grid.Row="0"
                            IsVisible="{Binding HasPendingElevatedHostsUpdate}"
                            Background="#3A2414"
                            BorderBrush="#7A4A1F"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0"
                                       Text="Pending hosts changes need administrator approval."
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="#FFD8A8" />
                            <Button Grid.Column="1"
                                    Content="Apply Now"
                                    Command="{Binding ApplyToSystemHostsCommand}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Text="Source Editor" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Name="SaveSelectedSourceButton" Content="Save" Click="SaveSelectedSourceClick" />
                        <TextBlock Grid.Column="2"
                                   Name="UnsavedIndicator"
                                   Text="Unsaved"
                                   IsVisible="False"
                                   Foreground="#FFCC80"
                                   Opacity="0.95"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="2" Spacing="8">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" Text="Name" />
                            <TextBox IsReadOnly="{Binding IsSelectedSourceReadOnly}" Text="{Binding SelectedProfile.Name, Mode=TwoWay}" Watermark="Source name" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Classes="label" Text="Type" VerticalAlignment="Center" />
                            <TextBlock Opacity="0.7" VerticalAlignment="Center" Text="{Binding SelectedSourceTypeDisplay}" />
                        </StackPanel>

                        <TextBlock IsVisible="{Binding IsSystemSelected}"
                                   Opacity="0.72"
                                   Text="{Binding HostsPath, StringFormat=System hosts file: {0}}" />

                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsVisible="{Binding IsSystemSelected}">
                            <CheckBox IsChecked="{Binding IsSystemHostsEditingEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center" Text="Enable direct system hosts editing" />
                        </StackPanel>
                        <TextBlock IsVisible="{Binding IsSystemSelected}"
                                   Opacity="0.68"
                                   Text="Disabled by default for safety. Enable only when you need to edit non-managed records." />
                    </StackPanel>

                    <views:LocalSourceEditorView Grid.Row="3"
                                                 DataContext="{Binding LocalEditor}" />

                    <views:RemoteSourceEditorView Grid.Row="4"
                                                  DataContext="{Binding RemoteEditor}" />

                    <TextBlock Grid.Row="5" Classes="label" Text="Hosts Entries" />

                    <Border Grid.Row="6" BorderBrush="#2F3742" BorderThickness="1" CornerRadius="6" Background="#141A22" Padding="2">
                        <ae:TextEditor Name="HostsEntriesEditor"
                                       IsReadOnly="{Binding IsSelectedEntriesReadOnly}"
                                       ShowLineNumbers="True"
                                       FontFamily="Consolas"
                                       Foreground="#E6EDF3"
                                       Background="#141A22"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       MinHeight="360" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Classes="panel" Grid.Row="1" Padding="10">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                <TextBlock Opacity="0.82" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                <Button Grid.Column="1" Content="Sync All Remote" Command="{Binding SyncAllFromUrlCommand}" />
                <Button Grid.Column="2" Content="Manual Apply" Command="{Binding ApplyToSystemHostsCommand}" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Text="Minimize to tray on close" />
                    <CheckBox IsChecked="{Binding MinimizeToTrayOnClose, Mode=TwoWay}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            IsVisible="{Binding CanConfigureRunAtStartup}">
                    <TextBlock VerticalAlignment="Center" Text="Run at Windows startup" />
                    <CheckBox IsChecked="{Binding RunAtStartup, Mode=TwoWay}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</Window>
