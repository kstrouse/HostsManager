<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.Desktop.ViewModels"
             x:Class="HostsManager.Desktop.Views.SourceListView"
             x:Name="Root"
             x:DataType="vm:SourceListViewModel">
    <Border Classes="panel" Padding="10">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Sources" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="＋"
                            ToolTip.Tip="Add source"
                            Click="OpenAddSourceMenuClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="New Local Source" Click="NewLocalSourceClick" />
                                <MenuItem Header="Existing Local Source" Click="AddLocalSourceClick" />
                                <MenuItem Header="New Remote Source" Click="NewRemoteSourceClick" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </StackPanel>

            <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="2">
                            <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Opacity="0.65" FontSize="11" Text="{Binding SourceTypeDisplay}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsEnabled="{Binding CanToggleEnabled}"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Checked="SourceEnabledChanged"
                                          Unchecked="SourceEnabledChanged" />
                            <Button Grid.Column="2"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Delete source"
                                    Content="🗑"
                                    Command="{ReflectionBinding #Root.DataContext.DeleteProfileCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
