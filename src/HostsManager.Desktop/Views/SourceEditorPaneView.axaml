<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HostsManager.Desktop.ViewModels"
             xmlns:views="using:HostsManager.Desktop.Views"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="HostsManager.Desktop.Views.SourceEditorPaneView"
             x:DataType="vm:SourceEditorPaneViewModel">
    <Border Classes="panel" Padding="12">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="8">
            <views:SelectedSourceDetailsView Grid.Row="0"
                                             DataContext="{Binding SelectedSourceDetails}" />

            <views:LocalSourceEditorView Grid.Row="1"
                                         DataContext="{Binding LocalEditor}" />

            <views:RemoteSourceEditorView Grid.Row="2"
                                          DataContext="{Binding RemoteEditor}" />

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="Hosts Entries" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Name="SaveSelectedSourceButton" Content="Save" Click="SaveSelectedSourceClick" />
                <TextBlock Grid.Column="2"
                           Name="UnsavedIndicator"
                           Text="Unsaved"
                           IsVisible="False"
                           Foreground="#FFCC80"
                           Opacity="0.95"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="4" BorderBrush="#2F3742" BorderThickness="1" CornerRadius="6" Background="#141A22" Padding="2">
                <ae:TextEditor Name="HostsEntriesEditor"
                               IsReadOnly="{Binding IsSelectedEntriesReadOnly}"
                               ShowLineNumbers="True"
                               FontFamily="Consolas"
                               Foreground="#E6EDF3"
                               Background="#141A22"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"
                               MinHeight="360" />
            </Border>
        </Grid>
    </Border>
</UserControl>
