<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HostsManager.ViewModels"
        x:Class="HostsManager.Views.QuickToggleWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Hosts Manager"
        Width="340"
        Height="420"
        MinWidth="300"
        MinHeight="260"
        MaxWidth="420"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Grid Margin="12" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <TextBlock Grid.Row="0" Text="Quick Source Toggle" FontSize="15" FontWeight="SemiBold" />

        <Border Grid.Row="1" BorderBrush="#2F3742" BorderThickness="1" CornerRadius="6" Background="#141A22" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="2,4">
                                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Opacity="0.65" FontSize="11" Text="{Binding SourceTypeDisplay}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsEnabled="{Binding CanToggleEnabled}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Checked="SourceEnabledChanged"
                                              Unchecked="SourceEnabledChanged" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Button Grid.Column="0" Content="Exit App" Click="ExitAppClick" />
            <Button Grid.Column="1" Content="Open Full Editor" Click="OpenFullEditorClick" />
        </Grid>
    </Grid>
</Window>
